# Convex client connection
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Local development only. Vite ignores this bypass in production builds.
VITE_AUTH_DISABLED=true

# Firebase Web app configuration (safe to expose to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Also configure the issuer in the Convex deployment:
# npx convex env set FIREBASE_PROJECT_ID <firebase-project-id>
#
# For the local Convex deployment only, match the browser bypass with:
# npx convex env set AUTH_DISABLED true
# Never set AUTH_DISABLED on staging or production.
#
# Server-only research credentials belong in the Convex environment, not here:
# LINKUP_API_KEY, HERMES_API_KEY, HERMES_URL, VIDEO_DB_API_KEY
